{
  "name": "maalata",
  "version": "1.0.6",
  "description": "2002 era retro canvas experience — latency pipeline + CRT post-processing over canvas-ultrafast",
  "type": "module",
  "main": "dist/maalata.umd.js",
  "module": "dist/maalata.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/maalata.es.js",
      "require": "./dist/maalata.umd.js"
    }
  },
  "workspaces": [
    "demo"
  ],
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit && npm run lint",
    "build": "npm run type-check && NODE_ENV=production vite build --mode production",
    "build:dev": "npm run type-check && NODE_ENV=development vite build --mode development",
    "build:all": "npm run build && npm run build -w demo",
    "build:dev-all": "npm run build:dev && npm run build:dev -w demo",
    "clean": "rm -rf dist demo/dist",
    "serve": "node scripts/server.js demo/dist 4173",
    "serve:demo": "npm run build:all && node scripts/server.js demo/dist 4173",
    "verify-demo": "npm run build:dev-all && node scripts/verify-demo.js"
  },
  "keywords": [
    "canvas",
    "webgl",
    "crt",
    "retro",
    "emulation",
    "typescript"
  ],
  "license": "AGPL-3.0-only",
  "dependencies": {
    "canvas-ultrafast": "^1.0.5"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@microsoft/api-extractor": "^7.57.2",
    "@types/node": "^22.19.11",
    "eslint": "^10.0.1",
    "globals": "^16.0.0",
    "playwright": "^1.58.2",
    "typescript": "~5.8.2",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-compression2": "^2.4.0",
    "vite-plugin-dts": "^4.5.4"
  }
}
